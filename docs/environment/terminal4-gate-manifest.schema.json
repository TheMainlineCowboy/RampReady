{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://themainlinecowboy.github.io/RampReady/schemas/terminal4-gate-manifest.schema.json",
  "title": "RampReady PHX Terminal 4 Gate Manifest",
  "type": "object",
  "required": ["schemaVersion", "corridor", "coordinateSystem", "gates"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "corridor": {
      "type": "object",
      "required": ["startGate", "endGate", "sourceRepository", "sourceAuthority"],
      "properties": {
        "startGate": { "const": "B15" },
        "endGate": { "const": "A1" },
        "sourceRepository": { "const": "TheMainlineCowboy/SkyHarborPhx" },
        "sourceAuthority": { "const": "scenery/KPHX_ADEX.BGL" }
      },
      "additionalProperties": false
    },
    "coordinateSystem": {
      "type": "object",
      "required": ["world", "local", "headingConvention", "manualCorrectionsSeparated"],
      "properties": {
        "world": { "type": "string", "minLength": 1 },
        "local": { "const": "RampReady +X right, +Y up, -Z forward, meters" },
        "headingConvention": { "const": "degrees true north clockwise" },
        "manualCorrectionsSeparated": { "const": true }
      },
      "additionalProperties": false
    },
    "gates": {
      "type": "array",
      "items": { "$ref": "#/$defs/gate" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "vector2": {
      "type": "object",
      "required": ["x", "z"],
      "properties": {
        "x": { "type": "number" },
        "z": { "type": "number" }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": ["source", "sourcePath", "sourceDerived", "manualCorrection"],
      "properties": {
        "source": { "enum": ["ADEX", "BGL placement", "converted geometry", "manual correction"] },
        "sourcePath": { "type": "string", "minLength": 1 },
        "sourceDerived": { "type": "boolean" },
        "manualCorrection": { "type": ["object", "null"] }
      },
      "additionalProperties": false
    },
    "pose": {
      "type": "object",
      "required": ["position", "headingDeg"],
      "properties": {
        "position": { "$ref": "#/$defs/vector2" },
        "headingDeg": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 }
      },
      "additionalProperties": false
    },
    "gate": {
      "type": "object",
      "required": [
        "id",
        "terminalSector",
        "worldCoordinates",
        "aircraftParkingReference",
        "aircraftNoseHeadingDeg",
        "noseGearStart",
        "tugApproachSpawn",
        "tugCaptureSpawn",
        "initialTugHeadingDeg",
        "safePushbackStartDirectionDeg",
        "stopTurnReferences",
        "clearanceConstraints",
        "provenance"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[AB][0-9]{1,2}$" },
        "terminalSector": { "type": "string", "minLength": 1 },
        "worldCoordinates": {
          "type": "object",
          "required": ["latitude", "longitude"],
          "properties": {
            "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
            "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
          },
          "additionalProperties": false
        },
        "aircraftParkingReference": { "$ref": "#/$defs/vector2" },
        "aircraftNoseHeadingDeg": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 },
        "noseGearStart": { "$ref": "#/$defs/vector2" },
        "tugApproachSpawn": { "$ref": "#/$defs/pose" },
        "tugCaptureSpawn": { "$ref": "#/$defs/pose" },
        "initialTugHeadingDeg": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 },
        "safePushbackStartDirectionDeg": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 },
        "stopTurnReferences": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "position", "kind"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "position": { "$ref": "#/$defs/vector2" },
              "kind": { "enum": ["stop", "turn-start", "turn-end", "clearance-check"] }
            },
            "additionalProperties": false
          }
        },
        "clearanceConstraints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "description", "minimumMeters"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 },
              "minimumMeters": { "type": "number", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "provenance": { "$ref": "#/$defs/provenance" }
      },
      "additionalProperties": false
    }
  }
}
